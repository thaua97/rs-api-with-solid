{
  "extends": "@rocketseat/eslint-config/node",
  "rules": {
    "camelcase": "off",
    "indent": ["error", "tab"],
    "no-useless-constructor": "off",
    "@typescript-eslint/no-useless-constructor": "error",
    "prettier/prettier": [
      "error",
      {
        "useTabs": true,
        "tabWidth": 2,
        "singleQuote": true,
      }
    ]
  }
}